POSTGRES_DB=dialer
POSTGRES_USER=dialer
POSTGRES_PASSWORD=dialer
APP_UID=1000
APP_GID=1000
# Database selection:
# auto   -> prefer host Postgres when reachable, otherwise use Docker Postgres
# host   -> always use host Postgres
# docker -> always use Docker Postgres
# direct -> use DATABASE_URL exactly
DATABASE_MODE=auto
DATABASE_URL=postgresql+psycopg2://dialer:dialer@postgres:5432/dialer
HOST_POSTGRES_HOST=
HOST_POSTGRES_PORT=5432
DOCKER_POSTGRES_HOST=postgres
DOCKER_POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOW_BOOTSTRAP=true
VERBOSE_DOCKER_LOGS=false
METRICS_STREAM_INTERVAL_SECONDS=2
RETRY_DELAY_SECONDS=300
ARI_BASE_URL=http://your-asterisk-host:8088/ari
ARI_WS_URL=ws://your-asterisk-host:8088/ari/events
ARI_USERNAME=dialer
ARI_PASSWORD=supersecret
ARI_APP_NAME=dialer-app
ARI_CONTROLLER_URL=http://ari-controller:8090
# Common outbound trunk formats:
# PJSIP/mytrunk-endpoint                      -> dials as PJSIP/{number}@mytrunk-endpoint
# PJSIP/{phone}@mytrunk-endpoint             -> explicit dial-string template
# PJSIP/mytrunk-endpoint/sip:{phone}@1.2.3.4 -> explicit request URI template
SIP_TRUNK_ENDPOINT=PJSIP/mytrunk-endpoint

# Browser SIP/WebRTC softphone values exposed to the web client.
# Use the websocket URL your Asterisk actually exposes:
# - ws://your-asterisk-host/ws for a proxy/reverse-proxy route
# - ws://your-asterisk-host:8088/ws for the built-in Asterisk HTTP server
VITE_SIP_URI=sip:1001@your-asterisk-host
VITE_SIP_PASSWORD=replace-me
VITE_SIP_WS_URL=ws://your-asterisk-host/ws
VITE_SIP_DISPLAY_NAME=Browser Agent
